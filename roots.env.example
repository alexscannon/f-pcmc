# Machine-specific root paths — copy to roots.env and edit. roots.env is
# gitignored; every environment (dev machine, CI, a fresh clone, another
# agent sandbox) sets its own. See data/README.md for the full contract.
PROJECT_ROOT=/path/to/this/repo

# Root of the precomputed-embeddings data directory. Never committed, never
# copied into this repo — F-PCMC reads .pt files directly from here.
DATA_ROOT=/path/to/data/directory

# Active embedding pool. Options: {DINOv3_large_32px (primary), ResNet50_32px (A6 ablation)}
EMBEDDINGS_DIR=${DATA_ROOT}/embeddings/DINOv3_large_32px
